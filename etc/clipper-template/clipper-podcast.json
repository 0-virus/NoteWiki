{
  "schemaVersion": "0.1.0",
  "name": "🎙️ 팟캐스트 (Podcast)",
  "behavior": "create",
  "noteContentFormat": "> [!info] 에피소드\n> {{url}}\n\n## 쇼노트\n{{description}}\n\n## 핵심 내용\n<!-- 자막·타임스탬프 메모를 붙여넣기 -->\n{{content}}\n\n---\n\n## 💭 내 메모\n<!-- 클리핑 후 직접 작성 — 왜 저장했나 · 핵심 takeaway · 궁금한 점. 인제스트 시 이 메모를 우선 반영한다. -->\n",
  "properties": [
    {
      "name": "source_type",
      "value": "podcast",
      "type": "text"
    },
    {
      "name": "title",
      "value": "{{title}}",
      "type": "text"
    },
    {
      "name": "url",
      "value": "{{url}}",
      "type": "text"
    },
    {
      "name": "show",
      "value": "{{schema:partOfSeries.name}}",
      "type": "text"
    },
    {
      "name": "host",
      "value": "{{author}}",
      "type": "text"
    },
    {
      "name": "duration",
      "value": "{{schema:duration}}",
      "type": "text"
    },
    {
      "name": "published",
      "value": "{{published}}",
      "type": "date"
    },
    {
      "name": "clipped",
      "value": "{{date}}",
      "type": "date"
    },
    {
      "name": "description",
      "value": "{{description}}",
      "type": "text"
    },
    {
      "name": "tags",
      "value": "clippings/podcast",
      "type": "multitext"
    }
  ],
  "triggers": [
    "https://podcasts.apple.com/",
    "https://open.spotify.com/episode/"
  ],
  "noteNameFormat": "{{title}}",
  "path": "raw/podcasts"
}
