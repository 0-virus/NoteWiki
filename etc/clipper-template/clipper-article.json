{
  "schemaVersion": "0.1.0",
  "name": "📄 아티클 (Article)",
  "behavior": "create",
  "noteContentFormat": "{{content}}\n\n---\n\n## 💭 내 메모\n<!-- 클리핑 후 직접 작성 — 왜 저장했나 · 핵심 takeaway · 궁금한 점. 인제스트 시 이 메모를 우선 반영한다. -->\n",
  "properties": [
    {
      "name": "source_type",
      "value": "article",
      "type": "text"
    },
    {
      "name": "title",
      "value": "{{title}}",
      "type": "text"
    },
    {
      "name": "url",
      "value": "{{url}}",
      "type": "text"
    },
    {
      "name": "author",
      "value": "{{author|split:\", \"}}",
      "type": "multitext"
    },
    {
      "name": "site",
      "value": "{{domain}}",
      "type": "text"
    },
    {
      "name": "published",
      "value": "{{published}}",
      "type": "date"
    },
    {
      "name": "clipped",
      "value": "{{date}}",
      "type": "date"
    },
    {
      "name": "description",
      "value": "{{description}}",
      "type": "text"
    },
    {
      "name": "tags",
      "value": "clippings/article",
      "type": "multitext"
    }
  ],
  "triggers": [],
  "noteNameFormat": "{{title}}",
  "path": "raw/articles"
}
