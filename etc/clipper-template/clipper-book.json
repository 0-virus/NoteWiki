{
  "schemaVersion": "0.1.0",
  "name": "📚 책 (Book)",
  "behavior": "create",
  "noteContentFormat": "![표지]({{image}})\n\n## 책 소개\n{{description}}\n\n## 발췌·하이라이트\n<!-- 읽으며 인상 깊은 구절을 옮겨 적기 -->\n\n## 챕터별 메모\n<!-- 챕터를 읽을 때마다 새 가지로 추가 -->\n\n---\n\n## 💭 내 메모\n<!-- 왜 읽는가 · 핵심 takeaway · 궁금한 점. 인제스트 시 이 메모를 우선 반영한다. -->\n",
  "properties": [
    {
      "name": "source_type",
      "value": "book",
      "type": "text"
    },
    {
      "name": "title",
      "value": "{{title}}",
      "type": "text"
    },
    {
      "name": "url",
      "value": "{{url}}",
      "type": "text"
    },
    {
      "name": "author",
      "value": "{{author|split:\", \"}}",
      "type": "multitext"
    },
    {
      "name": "publisher",
      "value": "{{schema:publisher.name}}",
      "type": "text"
    },
    {
      "name": "published",
      "value": "{{published}}",
      "type": "date"
    },
    {
      "name": "isbn",
      "value": "{{schema:isbn}}",
      "type": "text"
    },
    {
      "name": "clipped",
      "value": "{{date}}",
      "type": "date"
    },
    {
      "name": "description",
      "value": "{{description}}",
      "type": "text"
    },
    {
      "name": "tags",
      "value": "clippings/book",
      "type": "multitext"
    }
  ],
  "triggers": [
    "https://www.goodreads.com/book/",
    "https://www.aladin.co.kr/",
    "https://product.kyobobook.co.kr/",
    "https://www.yes24.com/"
  ],
  "noteNameFormat": "{{title}}",
  "path": "raw/books"
}
